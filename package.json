{
	"name": "birds",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 5178 --strictPort",
		"dev:test": "vite dev --host 127.0.0.1 --port 5178 --strictPort --mode test",
		"build": "vite build",
		"preview": "vite preview --port 5178",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"migrate": "./backend/db/migrate_pg.sh",
		"test:env": "./scripts/test-env-check.sh",
		"test:db:up": "./scripts/test-db-up.sh",
		"test:db:start": "./scripts/test-db-start.sh",
		"test:db:stop": "./scripts/test-db-stop.sh",
		"test:db:reset": "./scripts/test-db-reset.sh",
		"test:db:migrate": "./scripts/test-db-migrate.sh",
		"format": "prettier --write .",
		"lint": "prettier --check ."
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.2.12",
		"@sveltejs/kit": "^2.22.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.3",
		"@types/node": "^22.10.5",
		"@types/pg": "^8.11.10",
		"dotenv": "^17.4.2",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"svelte": "^5.17.3",
		"svelte-check": "^4.1.4",
		"tslib": "^2.8.1",
		"tsx": "^4.21.0",
		"typescript": "^5.7.3",
		"vite": "^6.0.7",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"argon2": "^0.44.0",
		"pg": "^8.13.1"
	}
}
